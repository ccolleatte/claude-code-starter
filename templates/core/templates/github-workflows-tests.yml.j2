name: tests
on: [push, pull_request]
jobs:
  unit-integration:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: '20' }
      - uses: actions/setup-python@v5
        with: { python-version: '3.12' }

      # Installation avec gestion d'erreur appropriée
      - name: Install Node dependencies
        run: |
          python .claude-meta/safe-runner.py --context ci_pipeline 'npm ci'

      - name: Install Python dependencies
        run: |
          python .claude-meta/safe-runner.py --context ci_pipeline 'pipx install pytest pytest-cov'

      - name: Create reports directory
        run: mkdir -p {{ reports_dir }}

      # Tests avec gestion granulaire
      - name: Run Node.js tests
        run: |
          python .claude-meta/safe-runner.py --context ci_pipeline 'npm run test:ci'

      - name: Run Python tests
        run: |
          python .claude-meta/safe-runner.py --context ci_pipeline 'pytest'

      - uses: actions/upload-artifact@v4
        with:
          name: test-reports
          path: {{ reports_dir }}