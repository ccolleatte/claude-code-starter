name: dependency-auto-update
on:
  schedule:
    # Vérification quotidienne à 2h00 UTC
    - cron: '0 2 * * *'
  workflow_dispatch:
    inputs:
      force_update:
        description: 'Force update all dependencies'
        required: false
        default: 'false'

jobs:
  security-scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          token: ${{ secrets.DEPENDENCY_UPDATE_TOKEN || github.token }}

      - uses: actions/setup-python@v5
        with: { python-version: '3.12' }

      # Vérification de sécurité des dépendances actuelles
      - name: Security scan current dependencies
        run: |
          python .claude-meta/dependency-manager.py verify
          python .claude-meta/checksum-updater.py verify

  check-updates:
    runs-on: ubuntu-latest
    needs: security-scan
    outputs:
      has_updates: ${{ steps.check.outputs.has_updates }}
      update_summary: ${{ steps.check.outputs.update_summary }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with: { python-version: '3.12' }

      - name: Check for updates
        id: check
        run: |
          # Vérifier les mises à jour disponibles
          UPDATE_OUTPUT=$(python .claude-meta/dependency-manager.py check-updates)
          echo "$UPDATE_OUTPUT"

          # Détecter s'il y a des mises à jour
          if echo "$UPDATE_OUTPUT" | grep -q "Updates available"; then
            echo "has_updates=true" >> $GITHUB_OUTPUT
            echo "update_summary<<EOF" >> $GITHUB_OUTPUT
            echo "$UPDATE_OUTPUT" >> $GITHUB_OUTPUT
            echo "EOF" >> $GITHUB_OUTPUT
          else
            echo "has_updates=false" >> $GITHUB_OUTPUT
            echo "update_summary=No updates available" >> $GITHUB_OUTPUT
          fi

  update-dependencies:
    runs-on: ubuntu-latest
    needs: check-updates
    if: needs.check-updates.outputs.has_updates == 'true' || github.event.inputs.force_update == 'true'
    steps:
      - uses: actions/checkout@v4
        with:
          token: ${{ secrets.DEPENDENCY_UPDATE_TOKEN || github.token }}

      - uses: actions/setup-python@v5
        with: { python-version: '3.12' }

      # Mise à jour des checksums
      - name: Update checksums
        run: |
          python .claude-meta/checksum-updater.py update --dry-run
          python .claude-meta/checksum-updater.py update

      # Test des nouvelles versions
      - name: Test updated dependencies
        run: |
          # Installer et tester chaque outil mis à jour
          python .claude-meta/dependency-manager.py verify

      # Vérification de sécurité post-mise à jour
      - name: Security verification
        run: |
          # Re-vérifier l'intégrité après mise à jour
          python .claude-meta/checksum-updater.py verify

          # Scanner les nouvelles versions pour vulnérabilités
          if command -v semgrep >/dev/null 2>&1; then
            semgrep --config=auto .claude-meta/ || true
          fi

      # Créer une PR avec les changements
      - name: Create Pull Request
        if: github.event_name == 'schedule'
        uses: peter-evans/create-pull-request@v5
        with:
          token: ${{ secrets.DEPENDENCY_UPDATE_TOKEN || github.token }}
          commit-message: |
            chore: update security tool dependencies

            ${{ needs.check-updates.outputs.update_summary }}

            🤖 Generated with [Claude Code](https://claude.ai/code)

            Co-Authored-By: Claude <noreply@anthropic.com>
          title: "🔒 Security Dependencies Update"
          body: |
            ## 🔄 Automated Dependency Update

            This PR contains automated updates to security tool dependencies.

            ### 📋 Changes Summary
            ```
            ${{ needs.check-updates.outputs.update_summary }}
            ```

            ### ✅ Verification Steps Completed
            - [x] Checksum integrity verification
            - [x] Security scan of updated dependencies
            - [x] Installation and functionality tests
            - [x] Vulnerability assessment

            ### 🧪 Test Plan
            - [ ] Manual verification of updated tools
            - [ ] Run full security scan pipeline
            - [ ] Validate CI/CD workflows

            ### 🚨 Security Review Required
            Please review the updated tool versions and checksums before merging.

            ---
            🤖 Generated with [Claude Code](https://claude.ai/code)
          branch: dependency-updates/automated
          delete-branch: true
          draft: false
          labels: |
            dependencies
            security
            automated

      # Application immédiate pour workflow_dispatch avec force
      - name: Apply updates immediately
        if: github.event.inputs.force_update == 'true'
        run: |
          echo "Force update requested - applying changes directly"
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add .
          git commit -m "chore: force update dependencies" || exit 0
          git push

  notify-security:
    runs-on: ubuntu-latest
    needs: [check-updates, update-dependencies]
    if: always() && (needs.check-updates.outputs.has_updates == 'true' || failure())
    steps:
      - name: Notify security team
        uses: 8398a7/action-slack@v3
        with:
          status: ${{ job.status }}
          text: |
            🔒 Security Dependencies Update Status: ${{ job.status }}

            Updates Available: ${{ needs.check-updates.outputs.has_updates }}
            Summary: ${{ needs.check-updates.outputs.update_summary }}

            Repository: ${{ github.repository }}
            Workflow: ${{ github.workflow }}
            Run: ${{ github.run_id }}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_SECURITY_WEBHOOK }}
        if: env.SLACK_WEBHOOK_URL != ''

  vulnerability-scan:
    runs-on: ubuntu-latest
    needs: update-dependencies
    if: needs.check-updates.outputs.has_updates == 'true'
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with: { python-version: '3.12' }

      # Scan complet de vulnérabilités après mise à jour
      - name: Comprehensive vulnerability scan
        run: |
          # Installer les outils mis à jour
          python .claude-meta/dependency-manager.py install --tool semgrep
          python .claude-meta/dependency-manager.py install --tool gitleaks
          python .claude-meta/dependency-manager.py install --tool trivy

          # Scanner le projet avec les nouvelles versions
          mkdir -p {{ reports_dir }}

          # SAST
          semgrep --config=auto --json --output={{ reports_dir }}/semgrep-post-update.json . || true

          # Secrets
          gitleaks detect --report-format json --report-path {{ reports_dir }}/gitleaks-post-update.json || true

          # Container/FS scan
          trivy fs --format json --output {{ reports_dir }}/trivy-post-update.json . || true

      - name: Upload security reports
        uses: actions/upload-artifact@v4
        with:
          name: post-update-security-reports
          path: {{ reports_dir }}
          retention-days: 30

      # Comparer avec les résultats précédents
      - name: Compare security results
        run: |
          echo "Security scan completed with updated dependencies"
          echo "Review artifact for detailed comparison with previous scan"