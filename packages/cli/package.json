{
  "name": "@claude/stack",
  "version": "1.0.0",
  "description": "Claude Stack CLI - Automated security stack management",
  "main": "dist/index.js",
  "bin": {
    "claude-stack": "dist/bin/claude-stack.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/claude-stack.js",
    "build:watch": "tsc --watch",
    "dev": "tsx src/bin/claude-stack.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "postbuild": "node scripts/post-build.js"
  },
  "keywords": [
    "claude",
    "security",
    "stack",
    "cli",
    "automation",
    "devops",
    "sast",
    "dependency-management"
  ],
  "author": "Claude Stack Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/claude-stack-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "yaml": "^2.3.4",
    "fs-extra": "^11.1.1",
    "semver": "^7.5.4",
    "glob": "^10.3.10",
    "axios": "^1.6.0",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/semver": "^7.5.4",
    "typescript": "^5.2.2",
    "tsx": "^4.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.6",
    "eslint": "^8.51.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "prettier": "^3.0.3"
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "profiles/**/*",
    "README.md"
  ]
}